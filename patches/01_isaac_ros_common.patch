+    IMPORTED_LOCATION "${TENSORRT_nvcaffe_parser_LIBRARY}"
+    INTERFACE_SYSTEM_INCLUDE_DIRECTORIES "${TENSORRT_INCLUDE_DIR}")
+endif()
+find_library(TENSORRT_nvparsers_LIBRARY NAMES nvparsers)
+if(TENSORRT_nvparsers_LIBRARY)
+  add_library(TENSORRT::nvparsers SHARED IMPORTED GLOBAL)
+  set_target_properties(TENSORRT::nvparsers PROPERTIES
+    IMPORTED_LOCATION "${TENSORRT_nvparsers_LIBRARY}"
+    INTERFACE_SYSTEM_INCLUDE_DIRECTORIES "${TENSORRT_INCLUDE_DIR}")
+endif()
 

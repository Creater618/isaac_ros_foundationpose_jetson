@@ -33,18 +33,19 @@
 find_path(TENSORRT_INCLUDE_DIR NAMES NvInferVersion.h REQUIRED)
 mark_as_advanced(TENSORRT_INCLUDE_DIR)
 
-# Find version
-function(read_version name str)
-    string(REGEX MATCH "${name} ([0-9]\\d*)" _ ${str})
-    set(${name} ${CMAKE_MATCH_1} PARENT_SCOPE)
-endfunction()
-
-file(READ "${TENSORRT_INCLUDE_DIR}/NvInferVersion.h" _TRT_VERSION_FILE)
-read_version(NV_TENSORRT_MAJOR ${_TRT_VERSION_FILE})
-read_version(NV_TENSORRT_MINOR ${_TRT_VERSION_FILE})
-read_version(NV_TENSORRT_PATCH ${_TRT_VERSION_FILE})
+# Find version - use file(STRINGS) for reliable line-by-line parsing (works on TRT 8 and 10)
+file(STRINGS "${TENSORRT_INCLUDE_DIR}/NvInferVersion.h" _TRT_VERSION_LINES)
+foreach(_line ${_TRT_VERSION_LINES})
+    if(_line MATCHES "#define NV_TENSORRT_MAJOR ([0-9]+)")
+        set(NV_TENSORRT_MAJOR ${CMAKE_MATCH_1})
+    elseif(_line MATCHES "#define NV_TENSORRT_MINOR ([0-9]+)")
+        set(NV_TENSORRT_MINOR ${CMAKE_MATCH_1})
+    elseif(_line MATCHES "#define NV_TENSORRT_PATCH ([0-9]+)")
+        set(NV_TENSORRT_PATCH ${CMAKE_MATCH_1})
+    endif()
+endforeach()
+unset(_TRT_VERSION_LINES)
 set(TENSORRT_VERSION "${NV_TENSORRT_MAJOR}.${NV_TENSORRT_MINOR}.${NV_TENSORRT_PATCH}")
-unset(_TRT_VERSION_FILE)
 

+void FoundationPoseTrackingNode::modelIdCallback(
+  const std_msgs::msg::String::ConstSharedPtr msg)
+{
+  if (!msg) {
+    return;
+  }
+
+  std::string model_id = msg->data;
+  // normalize
+  model_id.erase(0, model_id.find_first_not_of(" \t\n\r"));
+  model_id.erase(model_id.find_last_not_of(" \t\n\r") + 1);
+  std::transform(model_id.begin(), model_id.end(), model_id.begin(),
+                 [](unsigned char c) { return std::tolower(c); });
+
+  std::string mesh;
+  std::string texture;
+  {
+    std::lock_guard<std::mutex> lock(model_update_mutex_);
+    if (model_id == "k2" && !k2_mesh_file_path_.empty() && !k2_texture_path_.empty()) {
+      mesh = k2_mesh_file_path_;
+      texture = k2_texture_path_;
+    } else if (model_id == "j2" && !j2_mesh_file_path_.empty() && !j2_texture_path_.empty()) {
+      mesh = j2_mesh_file_path_;
+      texture = j2_texture_path_;
+    } else if (!other_mesh_file_path_.empty() && !other_texture_path_.empty()) {
+      mesh = other_mesh_file_path_;
+      texture = other_texture_path_;
+    } else {
+      // fallback: keep current mesh/texture
+      mesh = mesh_file_path_;
+      texture = texture_path_;
+    }
+
+    if (!graph_ready_) {
+      if (pending_mesh_file_path_ != mesh || pending_texture_path_ != texture) {
+        pending_mesh_file_path_ = mesh;
+        pending_texture_path_ = texture;
+      }
+      return;
+    }
+  }
+
+  // Apply outside the lock: applyModelPaths will call into GXF context.
+  applyModelPaths(mesh, texture);
+}
+
+void FoundationPoseTrackingNode::applyModelPaths(
+  const std::string & new_mesh_file_path, const std::string & new_texture_path)
+{
+  if (new_mesh_file_path.empty() || new_texture_path.empty()) {
+    return;
+  }
+
+  std::lock_guard<std::mutex> lock(model_update_mutex_);
+  if (new_mesh_file_path == mesh_file_path_ && new_texture_path == texture_path_) {
+    return;
+  }
+  mesh_file_path_ = new_mesh_file_path;
+  texture_path_ = new_texture_path;
+
+  // Update mesh/texture paths for render/transform/decoder blocks.
+  getNitrosContext().setParameterStr(
+    "render", "nvidia::isaac_ros::FoundationposeRender", "mesh_file_path", mesh_file_path_);
+  getNitrosContext().setParameterStr(
+    "render", "nvidia::isaac_ros::FoundationposeRender", "texture_path", texture_path_);
+
+  getNitrosContext().setParameterStr(
+    "transform", "nvidia::isaac_ros::FoundationposeTransformation", "mesh_file_path",
+    mesh_file_path_);
+  getNitrosContext().setParameterStr(
+    "decoder", "nvidia::isaac_ros::FoundationposeDecoder", "mesh_file_path", mesh_file_path_);
 }
 
